# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=devtaskr
POSTGRES_PASSWORD=devtaskr_password
POSTGRES_DB=devtaskr

# ── Backend / FastAPI ─────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Frontend / Next.js ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_SECRET=change-this-to-another-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# ── pgAdmin ───────────────────────────────────
PGADMIN_EMAIL=admin@devtaskr.com
PGADMIN_PASSWORD=admin

# ── Environment ───────────────────────────────
ENVIRONMENT=development
# Set DEBUG=true only for local development. Never enable in production.
DEBUG=false
